#1 font_family JetBrains Bold
# font_family SourceCodePro
cursor_shape block
cursor_blink_interval 0
shell_integration no-cursor
enable_audio_bell no


# BEGIN_KITTY_THEME
# Gruvbox Dark
include current-theme.conf
# END_KITTY_THEME


# BEGIN_KITTY_FONTS
font_family      family="DejaVu Sans Mono"
bold_font        auto
italic_font      auto
bold_italic_font auto
# END_KITTY_FONTS
